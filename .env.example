# ---------------------------------------------------------------------------
# Aligo Mission Ledger C2 - environment configuration (lab use only)
# Copy to .env and adjust as needed.
# ---------------------------------------------------------------------------

# C2 server bind address / port
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Database (SQLite by default; switch to PostgreSQL by changing this URL)
# Example Postgres URL: postgresql+psycopg://user:pass@db:5432/aligo
DATABASE_URL=sqlite:///./c2.db

# Shared secret presented by nodes on registration (NOT production-grade auth)
NODE_SHARED_TOKEN=change-me-lab-token

# Proof-of-Execution Ledger
LEDGER_ENABLED=true

# Local blockchain (Hardhat node) JSON-RPC endpoint
BLOCKCHAIN_RPC_URL=http://blockchain:8545

# Deployed ExecutionLedger contract address (filled after `make deploy-contract`)
CONTRACT_ADDRESS=

# Private key used by the server to send on-chain transactions.
# This is the well-known Hardhat account #0 key (LAB ONLY, never reuse).
BLOCKCHAIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Frontend origin allowed by CORS (https when using `python dev.py` TLS mode)
FRONTEND_URL=https://127.0.0.1:5173

# Node WebSocket URL (wss when TLS is enabled by dev.py)
# C2_WS_URL=wss://127.0.0.1:8000/ws/node

# ---------------------------------------------------------------------------
# Agent (AI orchestrator) — lab use only
# ---------------------------------------------------------------------------
# Anthropic API key for the Console "Ask AI" chat path. dev.py forwards this to
# the agent backend on :8100. Leave empty to run the stack without the AI chat
# (the manual console keeps working). Never commit a real key.
ANTHROPIC_API_KEY=
