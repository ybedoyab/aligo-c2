# ---------------------------------------------------------------------------
# Aligo Agent — environment configuration (lab use only)
# Copy to agents/orchestrator/.env and fill in ANTHROPIC_API_KEY before running the chat graph.
# This file is fully isolated from the C2 server's .env.
# ---------------------------------------------------------------------------

# Anthropic API key (required for the /chat LLM path; read-only smoke test is fine without it)
ANTHROPIC_API_KEY=

# Model + generation
AGENT_MODEL=claude-haiku-4-5
AGENT_MAX_TOKENS=8000

# C2 contract — the only external surface the agent consumes
C2_BASE_URL=http://localhost:8000
C2_WS_URL=ws://localhost:8000/ws/operator
C2_REQUEST_TIMEOUT=30

# Agent backend bind
AGENT_HOST=0.0.0.0
AGENT_PORT=8100
