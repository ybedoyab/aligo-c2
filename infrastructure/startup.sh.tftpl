#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# Aligo Mission Ledger C2 — VM first-boot provisioner.
# Rendered by Terraform (templatefile). Terraform substitutes its own tokens;
# all shell variables use the brace-less $VAR form so they pass through
# templatefile untouched. Output is teed to /var/log/aligo-startup.log.
# ---------------------------------------------------------------------------
set -euo pipefail

LOG=/var/log/aligo-startup.log
exec > >(tee -a "$LOG") 2>&1
echo "=== Aligo C2 startup begin: $(date -u) ==="

APP_DIR=/opt/aligo-c2
REPO_URL="${repo_url}"
REPO_BRANCH="${repo_branch}"
EXTERNAL_IP="${external_ip}"
ENABLE_AGENT="${enable_agent}"
CONTRACT_ADDRESS=""
# Deterministic fallback: account #0's first deployment on a fresh Hardhat chain.
DEFAULT_CONTRACT_ADDRESS="0x5FbDB2315678afecb367f032d93F642f64180aa3"

# ---------------------------------------------------------------------------
# 1. Base packages + Docker engine/compose plugin
# ---------------------------------------------------------------------------
export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get install -y ca-certificates curl git python3

if ! command -v docker >/dev/null 2>&1; then
  echo "Installing Docker..."
  curl -fsSL https://get.docker.com | sh
fi
systemctl enable --now docker

if ! docker compose version >/dev/null 2>&1; then
  apt-get install -y docker-compose-plugin
fi
docker compose version

# ---------------------------------------------------------------------------
# 2. Fetch the application source
# ---------------------------------------------------------------------------
if [ -d "$APP_DIR/.git" ]; then
  echo "Updating existing checkout at $APP_DIR"
  git -C "$APP_DIR" fetch --depth 1 origin "$REPO_BRANCH"
  git -C "$APP_DIR" checkout -B "$REPO_BRANCH" "origin/$REPO_BRANCH"
else
  echo "Cloning $REPO_URL ($REPO_BRANCH) -> $APP_DIR"
  rm -rf "$APP_DIR"
  git clone --depth 1 --branch "$REPO_BRANCH" "$REPO_URL" "$APP_DIR"
fi
cd "$APP_DIR"

COMPOSE="docker compose -f docker-compose.yml -f infrastructure/docker-compose.cloud.yml"

# ---------------------------------------------------------------------------
# 3. Render the .env consumed by docker compose
#    (CONTRACT_ADDRESS is filled in after the contract is deployed, step 6)
# ---------------------------------------------------------------------------
PUBLIC_AGENT_URL=""
if [ "$ENABLE_AGENT" = "true" ]; then
  PUBLIC_AGENT_URL="http://$EXTERNAL_IP:8100"
fi

cat > "$APP_DIR/.env" <<EOF
# Generated by the Terraform VM startup script — do not edit by hand.
NODE_SHARED_TOKEN=${node_shared_token}
LEDGER_ENABLED=true
BLOCKCHAIN_RPC_URL=http://blockchain:8545
BLOCKCHAIN_PRIVATE_KEY=${blockchain_private_key}
CONTRACT_ADDRESS=
PUBLIC_API_URL=http://$EXTERNAL_IP:8000
PUBLIC_FRONTEND_URL=http://$EXTERNAL_IP:5173
PUBLIC_AGENT_URL=$PUBLIC_AGENT_URL
ANTHROPIC_API_KEY=${anthropic_api_key}
EOF

PROFILE_ARGS=""
if [ "$ENABLE_AGENT" = "true" ]; then
  PROFILE_ARGS="--profile agent"
fi

# ---------------------------------------------------------------------------
# 4. Build all images up front. The blockchain image is built first so we can
#    export the contract ABI to the host before the server image is built
#    (server/app/blockchain/contract_abi.json is git-ignored and absent from a
#    fresh clone, so the server image must bake in the freshly extracted copy).
# ---------------------------------------------------------------------------
echo "Building blockchain image..."
$COMPOSE build blockchain

echo "Extracting contract ABI..."
$COMPOSE run --rm --no-deps -T --entrypoint sh blockchain \
  -c "cat artifacts/contracts/ExecutionLedger.sol/ExecutionLedger.json" > /tmp/exec_artifact.json

mkdir -p "$APP_DIR/server/app/blockchain"
python3 - <<'PY'
import json
art = json.load(open("/tmp/exec_artifact.json"))
out = "/opt/aligo-c2/server/app/blockchain/contract_abi.json"
json.dump(art["abi"], open(out, "w"), indent=2)
print(f"ABI written to {out} ({len(art['abi'])} entries)")
PY

echo "Building the remaining images..."
$COMPOSE $PROFILE_ARGS build

# ---------------------------------------------------------------------------
# 5. Start ONLY the chain, then deploy the contract. The chain is brought up
#    exactly once and is never rebuilt/recreated afterwards — otherwise the
#    Hardhat node (in-memory state) would restart and drop the deployed
#    contract, leaving every ledger event stuck "pending_chain".
# ---------------------------------------------------------------------------
echo "Starting blockchain..."
$COMPOSE up -d --no-build blockchain

echo "Waiting for blockchain to become healthy..."
for _ in $(seq 1 60); do
  status="$(docker inspect -f '{{.State.Health.Status}}' aligo-blockchain 2>/dev/null || echo starting)"
  if [ "$status" = "healthy" ]; then
    echo "blockchain healthy"
    break
  fi
  sleep 5
done

echo "Deploying ExecutionLedger contract..."
$COMPOSE exec -T blockchain npx hardhat run scripts/deploy.ts --network localhost || true

CONTRACT_ADDRESS="$($COMPOSE exec -T blockchain node -e "console.log(require('/deployment.json').address)" 2>/dev/null | tr -d '\r' | tail -n1 || true)"
if [ -z "$CONTRACT_ADDRESS" ]; then
  echo "Could not read deployed address; falling back to deterministic default"
  CONTRACT_ADDRESS="$DEFAULT_CONTRACT_ADDRESS"
fi
echo "CONTRACT_ADDRESS=$CONTRACT_ADDRESS"
sed -i "s|^CONTRACT_ADDRESS=.*|CONTRACT_ADDRESS=$CONTRACT_ADDRESS|" "$APP_DIR/.env"

# ---------------------------------------------------------------------------
# 6. Start the rest of the stack WITHOUT rebuilding (images are already built,
#    so --no-build guarantees the running chain is left untouched). The server
#    now boots with CONTRACT_ADDRESS set and a live contract, so its singleton
#    blockchain client connects and anchors events from the start.
# ---------------------------------------------------------------------------
echo "Starting the full stack..."
$COMPOSE $PROFILE_ARGS up -d --no-build

touch "$APP_DIR/READY"
echo "=== Aligo C2 startup complete: $(date -u) ==="
echo "Dashboard:   http://$EXTERNAL_IP:5173"
echo "API docs:    http://$EXTERNAL_IP:8000/docs"
if [ "$ENABLE_AGENT" = "true" ]; then
  echo "Agent:       http://$EXTERNAL_IP:8100/health"
fi
